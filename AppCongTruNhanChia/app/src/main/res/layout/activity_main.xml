<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:padding="5dp"
        android:layout_marginTop="15dp"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Số thứ nhất: "
            android:textSize="18dp"
            android:gravity="center"
            android:textColor="@color/design_default_color_primary_dark"/>
        <EditText
            android:id="@+id/edtSoThuNhat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mời nhập con số ở đây"
            />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:padding="5dp"
        android:layout_marginTop="15dp"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Số thứ hai: "
            android:textSize="18dp"
            android:gravity="center"
            android:textColor="@color/design_default_color_primary_dark"/>
        <EditText
            android:id="@+id/edtSoThuHai"
            android:paddingLeft="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mời nhập con số ở đây"
            />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:padding="5dp"
        android:layout_marginTop="15dp"
        android:gravity="center_horizontal"

        android:orientation="horizontal">
        <Button
            android:id="@+id/btnCong"
            android:layout_margin="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textSize="20dp"
            android:onClick="XuLyCong"
            />
        <Button
            android:id="@+id/btnTru"
            android:layout_margin="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="20dp"
            android:onClick="XuLyTru"

            />
        <Button
            android:id="@+id/btnNhan"
            android:layout_margin="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="*"
            android:textSize="20dp"
            android:onClick="XuLyNhan"


            />
        <Button
            android:id="@+id/btnChia"
            android:layout_margin="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/"
            android:textSize="20dp"
            android:onClick="XuLyChia"

            />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:padding="5dp"
        android:layout_marginTop="15dp"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Kết quả: "
            android:textSize="18dp"
            android:gravity="center"
            android:textColor="@color/design_default_color_primary_dark"/>
        <EditText
            android:id="@+id/edtKetQua"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nơi hiện kết quả"
            android:enabled="false"
            />
    </LinearLayout>
</LinearLayout>